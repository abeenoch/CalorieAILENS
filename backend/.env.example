# Google Gemini API
GOOGLE_API_KEY=your_key_here

# Groq API
GROQ_API_KEY=your_key_here

# Opik Configuration
OPIK_API_KEY=your_key_here
OPIK_WORKSPACE=your_workspace
OPIK_PROJECT_NAME=calorie-tracker

# Database
DATABASE_URL=sqlite+aiosqlite:///./calorie_tracker.db

# Server
HOST=0.0.0.0
PORT=8000

# USDA FDC API for nutrition data
FDC_API_KEY=

# JWT Authentication
JWT_SECRET_KEY=replace_with_a_random_32plus_char_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Security
ENABLE_API_DOCS=false
ENABLE_DEBUG_ROUTES=false
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_IMAGE_BYTES=5000000
MAX_HISTORY_LIMIT=100
SHARE_TOKEN_EXPIRE_DAYS=30
